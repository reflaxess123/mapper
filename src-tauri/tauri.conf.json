{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MindMapper",
  "version": "0.1.0",
  "identifier": "com.refla.tauri-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI MindMapper",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "puzix",
    "shortDescription": "AI mind-map generator powered by OpenRouter",
    "longDescription": "Turn any topic into an interactive, editable mind map. Generate nodes with any LLM via OpenRouter, expand branches with AI, and export to SVG/PNG.",
    "category": "Productivity",
    "copyright": "Copyright (c) 2026 puzix",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "compression": "lzma"
      }
    }
  }
}
